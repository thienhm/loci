{
  "name": "loci",
  "version": "0.1.0",
  "description": "Local-first AI ticket management system with MCP integration",
  "keywords": ["tickets", "mcp", "ai", "task-management", "local"],
  "homepage": "https://github.com/thienhm/loci",
  "repository": {
    "type": "git",
    "url": "https://github.com/thienhm/loci.git"
  },
  "license": "MIT",
  "bin": {
    "loci": "./packages/cli/src/index.ts"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "release": "bun run scripts/release.ts",
    "build": "bun run --filter '*' build",
    "dev": "concurrently --names server,web --prefix-colors blue,green \"bun run --cwd packages/server dev\" \"bun run --cwd packages/web dev\"",
    "test": "bun test --cwd packages/cli && bun test --cwd packages/server"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^8.1.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^12.1.0",
    "fastify": "^5.3.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
